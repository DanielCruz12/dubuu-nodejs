# Common Variables
NODE_ENV=
DB_ENGINE=

CORS_ORIGINS=

# PostgreSQL Configuration
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Traducciones (Google Cloud Translation API v2)
# Crear la key en: https://console.cloud.google.com/apis/credentials
# Habilitar "Cloud Translation API" en: https://console.cloud.google.com/apis/library/translate.googleapis.com
GOOGLE_TRANSLATE_API_KEY=
# Idiomas habilitados (códigos separados por coma). Por defecto: es,en
ENABLED_LOCALES=es,en